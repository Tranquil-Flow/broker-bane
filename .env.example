# BrokerBane Environment Variables
# Copy to .env and fill in your values

# LLM Provider for Stagehand browser automation
# Options: openai, anthropic, ollama
BROKERBANE_LLM_PROVIDER=openai
BROKERBANE_LLM_API_KEY=
BROKERBANE_LLM_MODEL=gpt-4o

# Ollama (local-first, zero data exfiltration)
# BROKERBANE_LLM_PROVIDER=ollama
# BROKERBANE_LLM_MODEL=llama3.2

# NopeCHA CAPTCHA solving (optional)
NOPECHA_API_KEY=

# Override config file location (default: ~/.brokerbane/config.yaml)
# BROKERBANE_CONFIG_PATH=
